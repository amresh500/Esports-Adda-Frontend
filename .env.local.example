# EsportsAdda frontend — environment template
# Copy to `.env.local` for local development. On Vercel, set in Project Settings → Environment Variables.

# Base URL of the deployed backend (no trailing slash, no /api suffix).
# Local dev: http://localhost:5000
# Production: https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
